{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Victory Garden Installer",
  "version": "0.1.0",
  "identifier": "com.victorygarden.installer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Victory Garden Installer",
        "width": 1180,
        "height": 920,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "resources": [
      "../../firmware-bundles/*"
    ]
  }
}
