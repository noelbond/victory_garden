<%
  zone_from_return_to = params[:return_to].to_s[%r{\A/zones/(\d+)\z}, 1]
  zone = Zone.find_by(id: params[:zone_id]) ||
         Zone.find_by(id: zone_from_return_to) ||
         Zone.where(crop_profile_id: @crop_profile.id).order(:id).first
%>

<%= turbo_frame_tag "zone_workspace", class: "card zone-workspace-page", data: { zone_workspace_target: "crop-profile" } do %>
  <div class="page-header crop-profile-page-header">
    <h1 class="page-title">Edit Crop Profile</h1>
    <% if zone.present? %>
      <div class="dashboard-actions">
        <%= link_to "Back to Zone", zone_path(zone), class: "btn light", data: { turbo_frame: "_top" } %>
      </div>
    <% end %>
  </div>

  <%= render "form", crop_profile: @crop_profile %>
<% end %>
