<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Ruby Service" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="app-header">
      <div class="app-title">Victory Garden</div>
      <nav class="app-nav">
        <%= link_to "Zones", zones_path, class: "nav-link" %>
        <%= link_to "Onboarding", onboarding_path, class: "nav-link" %>
        <%= link_to "Health", health_path, class: "nav-link" %>
        <%= link_to "Watering Events", watering_events_path, class: "nav-link" %>
        <%= link_to "Settings", settings_path, class: "nav-link" %>
      </nav>
    </header>

    <main class="app-main">
      <% if onboarding_incomplete? && controller_name != "onboarding" %>
        <div class="onboarding-banner">
          <div>
            <strong>Setup Incomplete</strong>
            <span class="muted">
              <%= onboarding_completed_count %> / <%= onboarding_steps.length %> steps complete.
            </span>
          </div>
          <div>
            <%= link_to "Open Onboarding", onboarding_path, class: "btn light" %>
          </div>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
