<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Victory Garden" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag :application, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="app-header">
      <details class="app-nav-menu" data-app-nav-menu open>
        <summary class="app-nav-toggle" aria-label="Open navigation menu">
          <span class="app-nav-toggle-lines" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
          <span class="sr-only">Menu</span>
        </summary>
        <nav class="app-nav">
          <%= link_to "Zones", zones_path, class: "nav-link" %>
          <%= link_to "Reading History", reading_history_path, class: "nav-link" %>
          <%= link_to "Health", health_path, class: "nav-link" %>
          <%= link_to "Watering Events", watering_events_path, class: "nav-link" %>
          <%= link_to "Settings", settings_path, class: "nav-link" %>
        </nav>
      </details>
      <div class="app-title" aria-label="Victory Garden">
        <span class="app-title-word">
          <span class="app-title-initial">V</span>
          <span class="app-title-rest">ictory</span>
        </span>
        <span class="app-title-word">
          <span class="app-title-initial">G</span>
          <span class="app-title-rest">arden</span>
        </span>
      </div>
    </header>

    <main class="app-main">
      <% if onboarding_incomplete? && controller_name != "onboarding" %>
        <div class="onboarding-banner">
          <div>
            <strong>Setup Incomplete</strong>
            <span class="muted">
              <%= onboarding_completed_count %> / <%= onboarding_steps.length %> steps complete.
            </span>
          </div>
          <div>
            <%= link_to "Open Setup Wizard", onboarding_path, class: "btn light" %>
          </div>
        </div>
      <% end %>
      <% flash.each do |type, message| %>
        <% next if message.blank? %>
        <div class="flash-banner <%= type.to_s == "alert" ? "flash-alert" : "flash-notice" %>">
          <%= message %>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
