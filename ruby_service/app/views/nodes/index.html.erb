<div class="page-header">
  <div>
    <h1 class="page-title">Nodes</h1>
    <div class="muted">Provisioned node identities discovered from MQTT state payloads.</div>
  </div>
  <div>
    <span class="env-pill"><%= Rails.env.production? ? "Production" : Rails.env.titleize %></span>
    <%= link_to "Zones", zones_path, class: "btn light" %>
  </div>
</div>

<% if @nodes.empty? %>
  <div class="card" style="margin-bottom: 16px;">
    <h3>No Nodes Discovered Yet</h3>
    <p class="muted">
      This app has not received any node state payloads yet, so there is nothing to assign.
    </p>
    <ul class="list">
      <li>Make sure the sensor node is powered on and publishing.</li>
      <li>Make sure this <strong><%= Rails.env.production? ? "production" : Rails.env.titleize.downcase %></strong> app is connected to the same MQTT broker as the node.</li>
      <li>Once a node publishes state, it will appear here automatically.</li>
    </ul>
    <div style="margin-top: 16px;">
      <%= link_to "Open Health", health_path, class: "btn" %>
      <%= link_to "Open Settings", settings_path, class: "btn light" %>
      <%= link_to "Open Setup Wizard", onboarding_path, class: "btn light" %>
    </div>
  </div>
<% end %>

<div class="card" style="margin-bottom: 16px;">
  <h3>Unassigned Nodes</h3>
  <% if @unassigned_nodes.any? %>
    <ul class="list node-directory-list">
      <% @unassigned_nodes.each do |node| %>
        <li class="node-directory-item">
          <strong><%= link_to node.node_id, node_path(node) %></strong>
          <div class="node-directory-meta">
            <div class="node-directory-line">Reported Zone ID: <%= node.reported_zone_id.presence || "—" %></div>
            <div class="node-directory-line">Last Seen: <%= node.last_seen_at %></div>
            <div class="node-directory-line">Health: <%= node.health.presence || "—" %></div>
            <div class="node-directory-line">Config Status: <%= node.config_status.presence || "—" %></div>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="muted">
      <% if @nodes.empty? %>
        No nodes have been discovered by this app yet.
      <% else %>
        No unassigned nodes discovered yet.
      <% end %>
    </p>
  <% end %>
</div>

<div class="card">
  <h3>Assigned Nodes</h3>
  <% if @assigned_nodes.any? %>
    <ul class="list node-directory-list">
      <% @assigned_nodes.each do |node| %>
        <li class="node-directory-item">
          <strong><%= link_to node.node_id, node_path(node) %></strong>
          <div class="node-directory-meta">
            <div class="node-directory-line">Zone: <%= node.zone&.name.presence || node.zone&.zone_id || "—" %></div>
            <div class="node-directory-line">Last Seen: <%= node.last_seen_at %></div>
            <div class="node-directory-line">Health: <%= node.health.presence || "—" %></div>
            <div class="node-directory-line">Config Status: <%= node.config_status.presence || "—" %></div>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="muted">
      <% if @nodes.empty? %>
        No assigned nodes yet because no nodes have been discovered.
      <% else %>
        No assigned nodes yet.
      <% end %>
    </p>
  <% end %>
</div>
