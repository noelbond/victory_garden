<%
  base_params = request.query_parameters.deep_symbolize_keys.except(:format)
  sort_params_for = lambda do |column|
    base_params.merge(sort: column, direction: next_sort_direction_for(column)).except(:page)
  end
  page_params_for = lambda do |page|
    base_params.merge(page: page)
  end
  export_csv_params = base_params.merge(format: :csv)
  table_column_widths = {
    "recorded_at" => "210px",
    "moisture_percent" => "130px",
    "moisture_raw" => "130px",
    "soil_temp_c" => "130px",
    "battery_percent" => "130px",
    "health" => "120px",
    "last_error" => "220px",
    "publish_reason" => "170px",
    "wifi_rssi" => "140px",
    "wake_count" => "130px",
    "uptime_seconds" => "130px"
  }
  column_value_for = lambda do |reading, column|
    case column
    when "recorded_at" then reading.recorded_at.utc.strftime("%Y-%m-%d %H:%M:%S UTC")
    when "moisture_percent" then reading.moisture_percent.present? ? "#{reading.moisture_percent}%" : "—"
    when "moisture_raw" then reading.moisture_raw || "—"
    when "soil_temp_c" then reading.soil_temp_c || "—"
    when "battery_percent" then reading.battery_percent.present? ? "#{reading.battery_percent}%" : "—"
    when "health" then reading.health || "—"
    when "last_error" then reading.last_error.presence || "none"
    when "publish_reason" then reading.publish_reason || "—"
    when "wifi_rssi" then reading.wifi_rssi || "—"
    when "wake_count" then reading.wake_count || "—"
    when "uptime_seconds" then reading.uptime_seconds || "—"
    else "—"
    end
  end
%>

<div class="page-header">
  <div>
    <h1 class="page-title"><%= @node.node_id %> Node Readings</h1>
    <div class="muted">
      <%= @total_readings %> reading<%= "s" unless @total_readings == 1 %>
      • <%= @from.utc.strftime("%Y-%m-%d %H:%M UTC") %> to <%= @to.utc.strftime("%Y-%m-%d %H:%M UTC") %>
      • <%= @active_filter_count %> active filter<%= "s" unless @active_filter_count == 1 %>
    </div>
  </div>
  <div class="dashboard-actions">
    <%= link_to "Back to Node", node_path(@node), class: "btn light" %>
  </div>
</div>

<div class="reading-history-layout">
  <details class="card reading-sidebar reading-sidebar-shell" data-reading-history-filters-shell open>
    <summary class="reading-sidebar-toggle">Filters</summary>
    <div class="reading-sidebar-inner">
      <div class="reading-sidebar-header">
        <h3>Filters</h3>
        <div class="muted">Filter this node's readings using the same history workflow as the global readings page.</div>
      </div>

      <%= form_with url: readings_node_path(@node), method: :get, local: true do %>
        <div class="field">
          <label for="timeframe">Timeframe</label>
          <%= select_tag :timeframe,
            options_for_select(NodesController::TIMEFRAME_OPTIONS.map { |value, label| [label, value] }, @timeframe),
            data: { reading_history_timeframe: true } %>
        </div>

        <div class="form-grid" data-reading-history-custom-range <%= "hidden" unless @timeframe == "custom" %>>
          <div class="field">
            <label for="from">From</label>
            <%= date_field_tag :from, @from.to_date.iso8601 %>
          </div>
          <div class="field">
            <label for="to">To</label>
            <%= date_field_tag :to, @to.to_date.iso8601 %>
          </div>
        </div>

        <div class="field">
          <label for="health">Health</label>
          <%= select_tag :health, options_for_select([["Any Health", nil]] + @health_options.map { |value| [value.titleize, value] }, params[:health]) %>
        </div>

        <div class="field">
          <label for="freshness">Freshness</label>
          <%= select_tag :freshness, options_for_select(@freshness_options, params[:freshness].to_s) %>
        </div>

        <div class="field">
          <label for="publish_reason">Publish Reason</label>
          <%= select_tag :publish_reason, options_for_select([["Any Publish Reason", nil]] + @publish_reason_options.map { |value| [value, value] }, params[:publish_reason]) %>
        </div>

        <div class="form-grid">
          <div class="field">
            <label for="moisture_min">Min Moisture %</label>
            <%= number_field_tag :moisture_min, params[:moisture_min], step: 0.1, min: 0, max: 100 %>
          </div>
          <div class="field">
            <label for="moisture_max">Max Moisture %</label>
            <%= number_field_tag :moisture_max, params[:moisture_max], step: 0.1, min: 0, max: 100 %>
          </div>
        </div>

        <div class="field checkbox-field">
          <label>
            <%= check_box_tag :errors_only, "1", params[:errors_only] == "1" %>
            Show only readings with errors
          </label>
        </div>

        <details class="reading-columns-picker">
          <summary>Columns</summary>
          <div class="reading-columns-grid">
            <% NodesController::TABLE_COLUMNS.each do |column, label| %>
              <label class="reading-column-option">
                <%= check_box_tag "columns[]", column, @selected_columns.include?(column) %>
                <span><%= label %></span>
              </label>
            <% end %>
          </div>
        </details>

        <div class="field">
          <label for="per_page">Results Per Page</label>
          <%= select_tag :per_page, options_for_select(NodesController::PER_PAGE_OPTIONS.map { |value| ["#{value} per page", value] }, @per_page) %>
        </div>

        <div class="reading-sidebar-actions">
          <%= submit_tag "Apply Filters", class: "btn" %>
          <%= link_to "Reset", readings_node_path(@node), class: "btn light" %>
        </div>
      <% end %>
    </div>
  </details>

  <div class="reading-history-content">
    <div class="health-metrics">
      <div class="card metric-card metric-ok">
        <div class="metric-label">Visible Readings</div>
        <div class="metric-value"><%= @total_readings %></div>
        <div class="muted">after current filters</div>
      </div>
      <div class="card metric-card <%= @error_reading_count.positive? ? "metric-warn" : "metric-ok" %>">
        <div class="metric-label">Readings With Errors</div>
        <div class="metric-value"><%= @error_reading_count %></div>
        <div class="muted">rows with a reported error</div>
      </div>
      <div class="card metric-card metric-ok">
        <div class="metric-label">Expected Interval</div>
        <div class="metric-value"><%= distance_of_time_in_words(Time.at(0), Time.at(@expected_interval_seconds)) %></div>
        <div class="muted">node publish cadence</div>
      </div>
      <div class="card metric-card metric-ok">
        <div class="metric-label">Page</div>
        <div class="metric-value"><%= @page %> / <%= @total_pages %></div>
        <div class="muted"><%= @per_page %> rows per page</div>
      </div>
    </div>

    <div class="row" style="margin-bottom: 16px;">
      <div class="col card">
        <h3>Publish Gaps</h3>
        <% if @publish_gaps.any? %>
          <ul class="list">
            <% @publish_gaps.each do |gap| %>
              <li>
                after <strong><%= gap[:after] %></strong>,
                resumed <strong><%= gap[:resumed_at] %></strong>,
                gap <strong><%= distance_of_time_in_words(Time.at(0), Time.at(gap[:duration_seconds])) %></strong>,
                missed about <strong><%= gap[:missed_intervals] %></strong> expected publish<%= "es" unless gap[:missed_intervals] == 1 %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="muted">No publish gaps larger than 1.5x the expected interval in this range.</p>
        <% end %>
      </div>

      <div class="col card">
        <h3>Current Calibration</h3>
        <ul class="list">
          <li>Dry Raw: <%= @node.moisture_raw_dry || "—" %></li>
          <li>Wet Raw: <%= @node.moisture_raw_wet || "—" %></li>
          <li>Expected Interval: <%= distance_of_time_in_words(Time.at(0), Time.at(@expected_interval_seconds)) %></li>
        </ul>
      </div>
    </div>

    <div class="card">
      <div class="zone-section-header">
        <div>
          <h3>Reading Results</h3>
          <div class="muted">Click a column header to sort ascending, then descending on the next click.</div>
        </div>
        <div class="reading-results-actions">
          <%= link_to "Export CSV", readings_node_path(@node, export_csv_params), class: "btn light" %>
        </div>
      </div>

      <% if @readings.any? %>
        <div class="health-table-wrap">
          <table class="health-table reading-results-table">
            <colgroup>
              <% table_columns.each do |column, _label| %>
                <col style="width: <%= table_column_widths.fetch(column, '160px') %>;">
              <% end %>
            </colgroup>
            <thead>
              <tr>
                <% table_columns.each do |column, label| %>
                  <th>
                    <%= link_to readings_node_path(@node, sort_params_for.call(column)), class: "table-sort-link" do %>
                      <span><%= label %></span>
                      <% if sort_column == column %>
                        <span class="table-sort-indicator"><%= sort_direction == "asc" ? "↑" : "↓" %></span>
                      <% end %>
                    <% end %>
                  </th>
                <% end %>
              </tr>
            </thead>
            <tbody>
              <% @readings.each do |reading| %>
                <tr>
                  <% table_columns.each do |column, _label| %>
                    <td><%= column_value_for.call(reading, column) %></td>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <div class="reading-pagination">
          <div class="muted">
            Showing <%= ((@page - 1) * @per_page) + 1 %> to <%= [@page * @per_page, @total_readings].min %> of <%= @total_readings %>
          </div>
          <div class="reading-pagination-actions">
            <% if @page > 1 %>
              <%= link_to "Previous", readings_node_path(@node, page_params_for.call(@page - 1)), class: "btn light" %>
            <% end %>
            <% if @page < @total_pages %>
              <%= link_to "Next", readings_node_path(@node, page_params_for.call(@page + 1)), class: "btn light" %>
            <% end %>
          </div>
        </div>
      <% else %>
        <p class="muted">No readings matched the current filter set.</p>
      <% end %>
    </div>
  </div>
</div>
