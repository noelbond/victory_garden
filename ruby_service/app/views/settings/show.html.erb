<div class="page-header">
  <h1 class="page-title">Settings</h1>
</div>

<div id="setup" class="card" style="margin-bottom: 16px;">
  <h3>Setup</h3>
  <p class="muted">
    Connection settings live here. The guided onboarding checklist is still available when you need to create zones,
    claim nodes, or verify initial setup progress.
  </p>
  <div style="margin-top: 16px;">
    <%= link_to "Open Onboarding Checklist", onboarding_path, class: "btn light" %>
  </div>
</div>

<div class="card">
  <h3>Connection Setup</h3>
  <%= form_with model: @setting, url: settings_path do |f| %>
    <div class="form-grid">
      <div class="field">
        <%= f.label :mqtt_host, "MQTT Host" %>
        <%= f.text_field :mqtt_host, placeholder: "localhost" %>
      </div>
      <div class="field">
        <%= f.label :mqtt_port, "MQTT Port" %>
        <%= f.number_field :mqtt_port, placeholder: "1883" %>
      </div>
      <div class="field">
        <%= f.label :mqtt_username, "MQTT Username" %>
        <%= f.text_field :mqtt_username, placeholder: "victory_garden" %>
      </div>
      <div class="field">
        <%= f.label :mqtt_password, "MQTT Password" %>
        <%= f.password_field :mqtt_password, placeholder: "Broker password" %>
      </div>
      <div class="field">
        <%= f.label :irrigation_line_count, "Installed Zones" %>
        <%= f.number_field :irrigation_line_count, min: 1, placeholder: "1" %>
      </div>
      <div class="field">
        <%= f.label :readings_topic, "Readings Topic" %>
        <%= f.text_field :readings_topic, placeholder: "greenhouse/zones/+/state" %>
      </div>
      <div class="field">
        <%= f.label :actuators_topic, "Actuators Topic" %>
        <%= f.text_field :actuators_topic, placeholder: "greenhouse/zones/+/actuator/status" %>
      </div>
      <div class="field">
        <%= f.label :command_topic, "Command Topic" %>
        <%= f.text_field :command_topic, placeholder: "greenhouse/zones/{zone_id}/actuator/command" %>
      </div>
      <div class="field">
        <%= f.label :config_topic, "Config Topic" %>
        <%= f.text_field :config_topic, placeholder: "greenhouse/system/config/current" %>
      </div>
      <div class="field">
        <%= f.label :bluetooth_enabled, "Bluetooth Enabled" %>
        <%= f.select :bluetooth_enabled, [[ "No", false ], [ "Yes", true ]] %>
      </div>
      <div class="field">
        <%= f.label :notes, "Notes" %>
        <%= f.text_field :notes, placeholder: "Optional notes" %>
      </div>
    </div>

    <div style="margin-top: 16px;">
      <%= f.submit "Save", class: "btn" %>
    </div>
    <p class="muted" style="margin-top: 12px;">
      Installed zones define how many valve-controlled outputs exist on the watering system.
      Each active zone is assigned to one matching zone number.
    </p>
  <% end %>

  <div style="margin-top: 16px;">
    <%= button_to "Publish Config", admin_publish_config_path, method: :post, class: "btn light" %>
  </div>
</div>
